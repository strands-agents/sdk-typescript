{
  "name": "strands",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "strands-ts",
    "strands-wasm",
    "filament-sdk-js",
    "strands-filament"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:sdk": "npm run build -w strands-ts",
    "build:wasm": "npm run build -w strands-wasm",
    "clean": "npm run clean --workspaces",
    "postinstall": "rm -rf node_modules/@bytecodealliance/componentize-js && ln -s ../../../../bytecodealliance/ComponentizeJS node_modules/@bytecodealliance/componentize-js"
  }
}
